# ── Database (Railway MySQL) ──────────────────────────────────────────────
# The app accepts either these DB_* names or Railway's built-in MySQL names:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_db_password
DB_NAME=railway

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=https://your-frontend.up.railway.app

# ── Prokerala Astrology API ───────────────────────────────────────────────
# Sign up free at https://api.prokerala.com
PROKERALA_CLIENT_ID=your_client_id
PROKERALA_CLIENT_SECRET=your_client_secret

# ── Email ─────────────────────────────────────────────────────────────────
# Railway Hobby blocks outbound SMTP, so use Resend's HTTPS API in production.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM="Ashtakoota <onboarding@resend.dev>"

# SMTP is fallback only for local dev or Railway Pro+.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_google_app_password
EMAIL_FROM="Ashtakoota ✦ <your_gmail@gmail.com>"

# ── Avatar uploads ────────────────────────────────────────────────────────
# On Railway Hobby, attach a persistent volume to the backend at /app/uploads
# and keep this relative path so existing /uploads/... URLs continue working.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
